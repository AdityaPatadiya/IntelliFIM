# =============================================================================
# IntelliFIM Docker compose environment.
# Copy to `.env.docker` and fill in. .env.docker is gitignored.
#
# Generate the two secret keys with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# =============================================================================

# ---- Required: secrets ----
DJANGO_SECRET_KEY=<paste-output-of-secrets-command>
SECRET_KEY=<paste-output-of-secrets-command>
POSTGRES_PASSWORD=<choose-a-strong-password>

# ---- Optional: override Postgres user / DB names ----
POSTGRES_USER=fim_user
POSTGRES_DB=fim_db

# ---- Optional: change host port mappings (avoid clashes) ----
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=8080
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

# ---- FIM monitoring source path ----
# Host directory tree the worker should be able to monitor. Bind-mounted into
# the container at /data/monitored — point the UI at /data/monitored/<sub>
# rather than the host path.
FIM_MONITORED_HOST_DIR=./Example

# ---- Frontend ----
# In dev compose the browser still hits the backend via the host port mapping.
# In prod it's served from the same origin via nginx (leave empty).
VITE_API_URL=http://localhost:8000
